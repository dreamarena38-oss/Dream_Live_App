{
  "expo": {
    "name": "Dream Live TV",
    "slug": "dream-live",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dreamlivetv",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B46C1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saimashraf.dreamlivetv",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Dream Live TV",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Dream Live TV uses your photo library so admins can upload match and league images.",
        "NSCameraUsageDescription": "Dream Live TV uses the camera so admins can capture images for match and league content.",
        "NSMicrophoneUsageDescription": "Dream Live TV may use the microphone when recording video for admin uploads.",
        "MetroBundlerHost": "localhost"
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#6B46C1"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.saimashraf.dreamlivetv"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withIosDeviceBundle.js",
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#6B46C1",
          "imageWidth": 280,
          "dark": {
            "image": "./assets/images/splash.png",
            "backgroundColor": "#4C1D95"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c231ef06-b32e-4f10-ac64-0a73c52a9134"
      }
    }
  }
}
