{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL_WEB": "https://dream-live-backend-3.onrender.com/api",
        "EXPO_PUBLIC_API_URL_ANDROID": "https://dream-live-backend-3.onrender.com/api",
        "EXPO_PUBLIC_API_URL_IOS": "https://dream-live-backend-3.onrender.com/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL_WEB": "https://dream-live-backend-3.onrender.com/api",
        "EXPO_PUBLIC_API_URL_ANDROID": "https://dream-live-backend-3.onrender.com/api",
        "EXPO_PUBLIC_API_URL_IOS": "https://dream-live-backend-3.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}