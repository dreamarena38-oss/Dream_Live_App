{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL_WEB": "https://dreamliveapp-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL_ANDROID": "https://dreamliveapp-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL_IOS": "https://dreamliveapp-production.up.railway.app/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL_WEB": "https://dreamliveapp-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL_ANDROID": "https://dreamliveapp-production.up.railway.app/api",
        "EXPO_PUBLIC_API_URL_IOS": "https://dreamliveapp-production.up.railway.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}