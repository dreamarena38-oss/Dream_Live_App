{
  "name": "dream-live",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "server": "npm run start --prefix backend",
    "server:dev": "npm run dev --prefix backend",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "start:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "ios:prebuild:dev": "expo prebuild --platform ios",
    "ios:pods": "cd ios && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 pod install",
    "ios:xcode": "open ios/DreamLiveTV.xcworkspace",
    "ios:release-bundle": "npx expo export:embed --platform ios --dev false",
    "ios:setup": "npm run ios:prebuild && npm run ios:pods && npm run ios:xcode",
    "start:metro": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || echo localhost) npx expo start --lan",
    "ios:simulator": "npx expo run:ios",
    "ios:run-device": "npx expo run:ios --device",
    "ios:device": "npm run start:metro & sleep 3 && npx expo run:ios --device",
    "ios:build:production": "eas build --platform ios --profile production",
    "ios:build:preview": "eas build --platform ios --profile preview",
    "ios:submit": "eas submit --platform ios --profile production",
    "clean": "rm -rf node_modules ios android .expo && (watchman watch-del-all 2>/dev/null || true)",
    "clean:cache": "rm -rf .expo node_modules/.cache && npx expo start -c",
    "android": "expo run:android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@types/socket.io-client": "^1.4.36",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^4.21.2",
    "http": "^0.0.1-security",
    "install": "^0.13.0",
    "lucide-react-native": "^0.475.0",
    "mongoose": "^8.16.2",
    "npm": "^11.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-web-webview": "^1.0.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-youtube-iframe": "^2.3.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "nodemon": "^3.1.10",
    "typescript": "~5.9.2"
  }
}
